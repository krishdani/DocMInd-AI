# ═══════════════════════════════════════════════════════════════
# DocuMind AI - Backend Environment Variables
# Copy this to .env and fill in your values
# ═══════════════════════════════════════════════════════════════

# ── App ──────────────────────────────────────────────────────────
APP_NAME=DocuMind AI
APP_VERSION=1.0.0
DEBUG=false
ENVIRONMENT=production

# ── Security (generate with: openssl rand -hex 32) ───────────────
SECRET_KEY=your-super-secret-key-change-this-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# ── PostgreSQL ───────────────────────────────────────────────────
DATABASE_URL=postgresql://documind_user:documind_pass@postgres:5432/documind_db

# ── Redis ────────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0
CACHE_TTL_SECONDS=3600

# ── OpenAI ───────────────────────────────────────────────────────
OPENAI_API_KEY=sk-your-openai-api-key-here
OPENAI_MODEL=gpt-4o
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
OPENAI_WHISPER_MODEL=whisper-1

# ── File Storage ─────────────────────────────────────────────────
UPLOAD_DIR=/app/uploads
MAX_FILE_SIZE_MB=500
FAISS_INDEX_PATH=/app/faiss_indexes

# ── CORS (comma separated in docker-compose) ─────────────────────
ALLOWED_ORIGINS=["http://localhost:3000","http://localhost:5173","http://localhost"]

# ── Rate Limiting ─────────────────────────────────────────────────
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW_SECONDS=60

# ── Chunking ─────────────────────────────────────────────────────
CHUNK_SIZE=1000
CHUNK_OVERLAP=200
TOP_K_RESULTS=5
